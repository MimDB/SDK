{
  "name": "@mimdb/react",
  "version": "0.2.3",
  "description": "React hooks for MimDB",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --outDir dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "@tanstack/react-query": ">=5.0.0",
    "@mimdb/client": ">=0.3.0",
    "@mimdb/realtime": ">=0.1.1"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "vitest": "^4.1.1",
    "typescript": "^6.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@types/react": "^18.3.0",
    "@tanstack/react-query": "^5.83.0",
    "@testing-library/react": "^16.3.0",
    "@mimdb/client": "^0.3.0",
    "@mimdb/realtime": "^0.2.0",
    "jsdom": "^26.1.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/MimDB/SDK",
    "directory": "packages/react"
  },
  "keywords": ["mimdb", "mimisbrunnr", "react", "hooks", "baas"]
}
